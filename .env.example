# Copy to .env.local and fill in. Never commit real keys (.env* is gitignored).

# Required — Anthropic API key. In production use a real key: sk-ant-...
ANTHROPIC_API_KEY=

# Optional — model for the agent harness.
# Production (genuine Anthropic): claude-opus-4-8 (best) or claude-sonnet-4-6 (cheaper/faster).
HARNESS_MODEL=claude-opus-4-8

# Optional — custom gateway base URL. Leave EMPTY to use the official Anthropic API.
# Only set this for a self-hosted / compatible gateway (e.g. OpenRouter: https://openrouter.ai/api).
ANTHROPIC_BASE_URL=
